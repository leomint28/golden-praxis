Options -MultiViews -Indexes
DirectoryIndex index.html
RewriteEngine On
RewriteBase /

# ── Security headers (Hostinger / Apache) ──
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  Header set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https://images.unsplash.com https://*.google.com https://*.googleapis.com https://*.gstatic.com; connect-src 'self' https://formspree.io; frame-src https://maps.google.com https://www.google.com; frame-ancestors 'self'; upgrade-insecure-requests"
</IfModule>

# ── Redirect *.html → clean URL (301) ──
RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [R=301,L]

RewriteCond %{THE_REQUEST} \s/+([^\s?]+)\.html[\s?] [NC]
RewriteRule ^(.+)\.html$ /%1 [R=301,L,NE]

# ── Serve /about as about.html ──
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^([^./]+)/?$ $1.html [L]
